# Copy to .env.local and fill in.

# From `supabase start` output (local dev) or your hosted Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS -- never expose to the client. Used by admin API routes/server actions.
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email). Needed starting Phase 2 (vendor approval emails).
RESEND_API_KEY=

# Stripe. Needed starting Phase 5 (checkout) / Phase 2 (Connect Express onboarding links).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
