# Copy to .env and fill in. Expo only exposes vars prefixed EXPO_PUBLIC_ to client code.

# From `supabase start` output (local dev) or your hosted Supabase project settings.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox public token (Geocoding + Directions). Needed starting Phase 2 (service address map pin).
EXPO_PUBLIC_MAPBOX_TOKEN=
