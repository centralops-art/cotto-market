  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "eslint": "^9.13.0",
    "supabase": "^2.20.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
